{
  "name": "study-accelerator",
  "version": "2.5.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "test": "npm run test:api && npm run test:web && npm run test:scripts",
    "test:api": "node apps/api/test/run-tests.js",
    "test:web": "npm test -w @study-accelerator/web",
    "test:scripts": "node --test scripts/test/*.test.js",
    "dev:web": "npm run dev -w @study-accelerator/web",
    "dev:api": "npm run dev -w @study-accelerator/api",
    "start:api": "npm run dev -w @study-accelerator/api",
    "dev:all": "node scripts/start-dev.mjs"
  }
}
